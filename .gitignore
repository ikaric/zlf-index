# ── Python bytecode ──────────────────────────────────────────
__pycache__/
*.py[codz]
*$py.class

# ── C / Cython build artifacts ──────────────────────────────
*.so
src/zlfi/_core.c
cython_debug/
build/
*.egg-info/
*.egg
.installed.cfg
MANIFEST

# ── Distribution / packaging ────────────────────────────────
.Python
develop-eggs/
dist/
downloads/
eggs/
.eggs/
wheels/
sdist/

# ── Datasets (large, downloaded by benchmarks) ──────────────
datasets/

# ── Benchmark output logs (regenerated by make benchmark-*) ─
.benchmarks/

# ── Test / coverage ─────────────────────────────────────────
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/

# ── Type checking ───────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# ── Linting / formatting ────────────────────────────────────
.ruff_cache/

# ── Environments / secrets ──────────────────────────────────
.env
.envrc
.venv
env/
venv/
ENV/

# ── Lock files (keep uv.lock for reproducibility) ──────────
# uv.lock is tracked intentionally

# ── Editor / IDE ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Cursor AI ───────────────────────────────────────────────
.cursorignore
.cursorindexingignore

